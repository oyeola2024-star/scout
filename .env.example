# Copy each NAME and VALUE into Vercel exactly as shown after replacing only the values issued by your own Supabase and Google Cloud projects.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY

# Final Vercel production URL, without a trailing slash
NEXT_PUBLIC_APP_URL=https://YOUR_PROJECT.vercel.app

# Google Gmail OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET

# Scout always uses a 250-per-Gmail deployment ceiling.
SCOUT_DEPLOYMENT_DAILY_CAP=250

# Generate one long random value. Paste the same value into both variables and Supabase Vault.
SCHEDULE_WORKER_SECRET=YOUR_ONE_LONG_RANDOM_SECRET
CRON_SECRET=YOUR_ONE_LONG_RANDOM_SECRET
